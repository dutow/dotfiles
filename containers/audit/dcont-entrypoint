#!/usr/bin/env bash
# dcont-entrypoint — image ENTRYPOINT; runs egress init, sets up the
# per-context persist tree, runs the user's init.sh, then execs CMD.
set -e

case "${DCONT_AUDIT_MODE:-off}" in
    strict) sudo /usr/local/sbin/dcont-egress-init ;;
esac

export AICONT_PERSIST="$HOME/.aicontext/persist"
mkdir -p "$AICONT_PERSIST/bin" "$AICONT_PERSIST/npm" "$AICONT_PERSIST/python"
export PATH="$AICONT_PERSIST/bin:$AICONT_PERSIST/npm/bin:$AICONT_PERSIST/python/bin:$PATH"
export NPM_CONFIG_PREFIX="$AICONT_PERSIST/npm"
export PYTHONUSERBASE="$AICONT_PERSIST/python"

# JVM tools (sdkmanager, gradle, maven, kotlinc, …) ignore HTTPS_PROXY
# and only honor -Dhttps.proxyHost/Port via JAVA_TOOL_OPTIONS. Mirror the
# audit proxy into the JVM so Java apps route through it too.
if [ -n "${HTTPS_PROXY:-}" ]; then
    proxy_hp="${HTTPS_PROXY#*://}"; proxy_hp="${proxy_hp%/}"
    proxy_host="${proxy_hp%%:*}"
    proxy_port="${proxy_hp##*:}"
    export JAVA_TOOL_OPTIONS="${JAVA_TOOL_OPTIONS:+$JAVA_TOOL_OPTIONS }-Dhttps.proxyHost=$proxy_host -Dhttps.proxyPort=$proxy_port -Dhttp.proxyHost=$proxy_host -Dhttp.proxyPort=$proxy_port -Dhttp.nonProxyHosts=localhost|127.0.0.1"
fi

if [ -x "$HOME/.aicontext/init.sh" ]; then
    "$HOME/.aicontext/init.sh" 2>&1 | tee "$HOME/.aicontext/init.log"
    rc=${PIPESTATUS[0]}
    if [ "$rc" -ne 0 ]; then
        echo "[dcont] init.sh failed (exit $rc) — see ~/.aicontext/init.log" >&2
    fi
fi

if [ $# -eq 0 ]; then
    exec /bin/zsh
fi
exec "$@"
