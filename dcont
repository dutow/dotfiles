#!/usr/bin/env bash
set -e

BASEDIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

detect_runtime() {
    local override="${1:-${DCONT_RUNTIME:-}}"
    if [ -n "$override" ]; then
        echo "$override"
        return
    fi
    if command -v podman &>/dev/null; then
        echo "podman"
    elif command -v docker &>/dev/null; then
        echo "docker"
    else
        echo "ERROR: Neither podman nor docker found" >&2
        exit 1
    fi
}

pick_free_port() {
    python3 -c 'import socket; s=socket.socket(); s.bind(("127.0.0.1",0)); print(s.getsockname()[1]); s.close()'
}

start_mitmproxy() {
    local log_dir="$1"
    local port="$2"
    local blocklist="${3:-}"
    DCONT_AUDIT_LOG_DIR="$log_dir" \
    DCONT_AUDIT_PORT="$port" \
    DCONT_AUDIT_BLOCKLIST="$blocklist" \
    nohup "$HOME/.local/bin/dcont-mitmproxy" >/dev/null 2>&1 &
    echo $!
}

wait_for_proxy_ready() {
    local port="$1"
    local pid="$2"
    local i=0
    while [ $i -lt 50 ]; do
        if ! kill -0 "$pid" 2>/dev/null; then
            echo "ERROR: mitmproxy died during startup. Check $DCONT_AUDIT_LOG_DIR/proxy.log" >&2
            return 1
        fi
        if ss -lnt 2>/dev/null | awk '{print $4}' | grep -q ":$port\$"; then
            return 0
        fi
        sleep 0.1
        i=$((i + 1))
    done
    echo "ERROR: mitmproxy did not bind port $port within 5s" >&2
    return 1
}

declare -A DISTRO_IMAGES=(
    [ubuntu-24.04]="ubuntu:24.04"
    [ubuntu-22.04]="ubuntu:22.04"
    [tumbleweed]="opensuse/tumbleweed"
    [oracle-9]="oraclelinux:9"
    [oracle-8]="oraclelinux:8"
)

declare -A DISTRO_BOOTSTRAP=(
    [ubuntu-24.04]="apt-get update && apt-get install -y python3 python3-pip ansible git sudo hostname locales && locale-gen en_US.UTF-8"
    [ubuntu-22.04]="apt-get update && apt-get install -y python3 python3-pip ansible git sudo hostname locales && locale-gen en_US.UTF-8"
    [tumbleweed]="zypper --non-interactive dup && zypper install -y python3 ansible git-core sudo hostname glibc-locale"
    [oracle-9]="dnf install -y python3 python3-pip ansible-core git sudo hostname glibc-langpack-en"
    [oracle-8]="dnf install -y python3 python3-pip ansible-core git sudo hostname glibc-langpack-en"
)

ALL_SETS="cpp-dev,ruby-dev,node-dev,python-dev,selenium,android-dev,ai-tools,development-tools"
DEFAULT_DISTRO="tumbleweed"
IMAGE_PREFIX="dotfiles"

cmd_build() {
    local distro="$DEFAULT_DISTRO"
    local sets="$ALL_SETS"
    local tag=""
    local runtime=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --distro)  distro="$2"; shift 2 ;;
            --sets)    sets="$2"; shift 2 ;;
            --tag)     tag="$2"; shift 2 ;;
            --runtime) runtime="$2"; shift 2 ;;
            *) echo "Unknown build option: $1" >&2; exit 1 ;;
        esac
    done

    if [ -z "${DISTRO_IMAGES[$distro]+x}" ]; then
        echo "ERROR: Unknown distro '$distro'. Available: ${!DISTRO_IMAGES[*]}" >&2
        exit 1
    fi

    local rt
    rt=$(detect_runtime "$runtime")
    tag="${tag:-$distro}"
    local image_name="${IMAGE_PREFIX}-${tag}"
    local base_image="${DISTRO_IMAGES[$distro]}"
    local bootstrap="${DISTRO_BOOTSTRAP[$distro]}"
    local build_container="dotfiles-build-$$"

    local sudo_password_file="$BASEDIR/.container_sudo_password"
    if [ ! -f "$sudo_password_file" ]; then
        echo "ERROR: $sudo_password_file not found." >&2
        echo "Generate it with: openssl passwd -6 'your-password' > .container_sudo_password" >&2
        exit 1
    fi
    local sudo_password_hash
    sudo_password_hash=$(<"$sudo_password_file")
    if [ -z "$sudo_password_hash" ]; then
        echo "ERROR: $sudo_password_file is empty." >&2
        exit 1
    fi

    local host_user
    host_user=$(id -un)
    local host_uid
    host_uid=$(id -u)
    local host_gid
    host_gid=$(id -g)

    local ca_src="$HOME/.mitmproxy/mitmproxy-ca-cert.pem"
    local ca_staged="$BASEDIR/.mitmproxy-ca-cert.pem"
    if [ -f "$ca_src" ]; then
        cp "$ca_src" "$ca_staged"
        echo "==> Staged mitmproxy CA for image build"
    else
        echo "WARNING: $ca_src not found. Image will not have mitmproxy CA trust."
        echo "         Run: mitmdump --version  (to seed)  then re-run dcont build."
        rm -f "$ca_staged"
    fi

    trap "$rt rm -f $build_container &>/dev/null || true; rm -f \"$ca_staged\"" EXIT

    echo "Building image: $image_name"
    echo "  Distro:  $distro ($base_image)"
    echo "  Sets:    $sets"
    echo "  Runtime: $rt"
    echo "  User:    $host_user ($host_uid:$host_gid)"
    echo

    echo "==> Creating build container..."
    "$rt" run -d --name "$build_container" "$base_image" sleep infinity

    echo "==> Bootstrapping packages..."
    "$rt" exec "$build_container" bash -c "$bootstrap"

    echo "==> Creating user $host_user..."
    "$rt" exec "$build_container" bash -c "
        groupadd -g $host_gid $host_user 2>/dev/null || true
        useradd -m -u $host_uid -g $host_gid -s /bin/bash $host_user 2>/dev/null || true
        echo '$host_user ALL=(ALL) NOPASSWD: ALL' > /etc/sudoers.d/$host_user
        chmod 0440 /etc/sudoers.d/$host_user
    "

    echo "==> Copying dotfiles repo..."
    "$rt" cp "$BASEDIR/." "$build_container:/home/$host_user/.dotfiles"
    "$rt" exec "$build_container" chown -R "$host_uid:$host_gid" "/home/$host_user/.dotfiles"

    "$rt" exec --user "$host_uid" --env "HOME=/home/$host_user" "$build_container" \
        git config --global --add safe.directory "/home/$host_user/.dotfiles"

    echo "==> Setting up .aicontext symlinks..."
    "$rt" exec --user "$host_uid" --env "HOME=/home/$host_user" "$build_container" bash -c "
        mkdir -p /home/$host_user/.aicontext/claude /home/$host_user/.aicontext/codex
        ln -sfn /home/$host_user/.aicontext/claude /home/$host_user/.claude
        ln -sfn /home/$host_user/.aicontext/codex /home/$host_user/.codex
    "

    echo "==> Running install.sh --container --env console --sets $sets ..."
    "$rt" exec --user "$host_uid" --env "HOME=/home/$host_user" \
        --workdir "/home/$host_user/.dotfiles" "$build_container" \
        ./install.sh --container --env console --sets "$sets"

    echo "==> Locking down sudo..."
    printf '%s:%s\n' "$host_user" "$sudo_password_hash" | "$rt" exec -i "$build_container" chpasswd --encrypted
    # Verify password was set (account should not be locked)
    "$rt" exec "$build_container" bash -c "passwd -S $host_user"
    "$rt" exec "$build_container" bash -c "
        echo 'Defaults !targetpw' > /etc/sudoers.d/$host_user
        echo '$host_user ALL=(ALL) ALL' >> /etc/sudoers.d/$host_user
        chmod 0440 /etc/sudoers.d/$host_user
    "

    echo "==> Committing image..."
    "$rt" commit \
        --change "USER $host_user" \
        --change "WORKDIR /home/$host_user" \
        --change "ENV CLAUDE_CONFIG_DIR=/home/$host_user/.claude" \
        --change "ENV LANG=en_US.UTF-8" \
        --change "ENV DEBUGINFOD_URLS=https://debuginfod.opensuse.org/" \
        --change 'ENTRYPOINT ["/usr/local/sbin/dcont-entrypoint"]' \
        --change 'CMD ["/bin/zsh"]' \
        "$build_container" "$image_name"

    echo
    echo "Image built: $image_name"
    echo "Run with: $0 run --tag $tag"
}

cmd_run() {
    local tag="${DCONT_TAG:-$DEFAULT_DISTRO}"
    local mounts=()
    local networks=()
    local context="${DCONT_CONTEXT:-default}"
    local shell="${DCONT_SHELL:-/bin/zsh}"
    local runtime="${DCONT_RUNTIME:-}"
    local gpu=false
    case "${DCONT_GPU:-}" in
        1|true|yes|on) gpu=true ;;
    esac
    local audit_mode="${DCONT_AUDIT:-strict}"
    local extra_cmd=()

    # Pre-populate mounts/networks from env (newline-separated for multiple,
    # plain string for a single value). Pairs nicely with zsh tied arrays:
    #   typeset -T DCONT_MOUNT dcont_mount $'\n'
    #   dcont_mount=(/path/a /path/b:/inside)
    #   export DCONT_MOUNT
    if [ -n "${DCONT_MOUNT:-}" ]; then
        while IFS= read -r line; do
            [ -n "$line" ] && mounts+=("$line")
        done <<< "$DCONT_MOUNT"
    fi
    if [ -n "${DCONT_NETWORK:-}" ]; then
        while IFS= read -r line; do
            [ -n "$line" ] && networks+=("$line")
        done <<< "$DCONT_NETWORK"
    fi

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --tag)     tag="$2"; shift 2 ;;
            --mount)   mounts+=("$2"); shift 2 ;;
            --network) networks+=("$2"); shift 2 ;;
            --context) context="$2"; shift 2 ;;
            --shell)   shell="$2"; shift 2 ;;
            --runtime) runtime="$2"; shift 2 ;;
            --gpu)     gpu=true; shift ;;
            --audit=*) audit_mode="${1#--audit=}"; shift ;;
            --audit)   audit_mode="$2"; shift 2 ;;
            --) shift; extra_cmd=("$@"); break ;;
            *) echo "Unknown run option: $1" >&2; exit 1 ;;
        esac
    done

    case "$audit_mode" in
        strict|soft|off) ;;
        *) echo "ERROR: --audit must be strict, soft, or off (got: $audit_mode)" >&2; exit 1 ;;
    esac

    if [ "$audit_mode" = "strict" ]; then
        for n in "${networks[@]}"; do
            if [ "$n" = "host" ]; then
                echo "ERROR: --audit=strict is incompatible with --network host" >&2
                exit 1
            fi
        done
    fi

    local rt
    rt=$(detect_runtime "$runtime")
    local image_name="${IMAGE_PREFIX}-${tag}"

    local aicont_dir="${DOTFILES_AICONT_DIR:-$HOME/.aicont}"
    local ctx_dir="$aicont_dir/$context"
    mkdir -p "$ctx_dir/claude" "$ctx_dir/codex" "$ctx_dir/persist"

    # Sync system-level CLAUDE.md into the context's claude dir
    local src_claude_md="$HOME/.claude/CLAUDE.md"
    local dst_claude_md="$ctx_dir/claude/CLAUDE.md"
    if [ -f "$src_claude_md" ]; then
        if [ ! -f "$dst_claude_md" ] || ! cmp -s "$src_claude_md" "$dst_claude_md"; then
            cp "$src_claude_md" "$dst_claude_md"
        fi
    fi

    local host_user
    host_user=$(id -un)

    local run_args=(run --rm)
    if [ -t 0 ] && [ -t 1 ]; then
        run_args+=(-it)
    fi

    if [ "$rt" = "podman" ]; then
        run_args+=(--userns=keep-id)
    else
        run_args+=(--user "$(id -u):$(id -g)")
    fi

    run_args+=(--shm-size=2g --tmpfs /run/tmux:mode=1777 --security-opt seccomp=unconfined --security-opt label=disable)

    run_args+=(-v "$ctx_dir:/home/$host_user/.aicontext")

    local audit_log_dir=""
    local audit_port=""
    local audit_pid=""
    local audit_proxy_host=""
    if [ "$audit_mode" != "off" ]; then
        local ts
        ts="$(date -u +%Y-%m-%dT%H-%M-%SZ)"
        audit_log_dir="$HOME/.aicont-logs/$context/$ts"
        mkdir -p "$audit_log_dir"
        ln -sfn "$ts" "$HOME/.aicont-logs/$context/latest"

        audit_port="$(pick_free_port)"
        local blocklist=""
        [ -f "$HOME/.config/dcont/blocklist.txt" ] && blocklist="$HOME/.config/dcont/blocklist.txt"
        # Export DCONT_AUDIT_LOG_DIR so wait_for_proxy_ready can reference it
        # in error messages if mitmproxy dies during startup.
        export DCONT_AUDIT_LOG_DIR="$audit_log_dir"
        audit_pid="$(start_mitmproxy "$audit_log_dir" "$audit_port" "$blocklist")"
        if ! wait_for_proxy_ready "$audit_port" "$audit_pid"; then
            kill "$audit_pid" 2>/dev/null || true
            exit 1
        fi
        trap "kill $audit_pid 2>/dev/null || true" EXIT

        if [ "$rt" = "podman" ]; then
            audit_proxy_host="host.containers.internal"
        else
            audit_proxy_host="host.docker.internal"
            run_args+=(--add-host=host.docker.internal:host-gateway)
        fi
        run_args+=(
            --cap-add=NET_ADMIN
            -e "DCONT_AUDIT_MODE=$audit_mode"
            -e "DCONT_PROXY_HOST=$audit_proxy_host"
            -e "DCONT_PROXY_PORT=$audit_port"
            -e "HTTPS_PROXY=http://${audit_proxy_host}:${audit_port}"
            -e "HTTP_PROXY=http://${audit_proxy_host}:${audit_port}"
            -e "NO_PROXY=localhost,127.0.0.1,::1"
        )
        echo "==> Audit mode: $audit_mode (port $audit_port, log $audit_log_dir)"
    fi

    for network in "${networks[@]}"; do
        run_args+=(--network "$network")
    done

    if [ "$gpu" = true ]; then
        run_args+=(--device nvidia.com/gpu=all)

        # Pass through NVIDIA Vulkan ICD
        local nvidia_icd="/usr/share/vulkan/icd.d/nvidia_icd.x86_64.json"
        if [ -f "$nvidia_icd" ]; then
            run_args+=(-v "$nvidia_icd:$nvidia_icd:ro")
        fi

        # Pass through Wayland display
        if [ -n "$WAYLAND_DISPLAY" ]; then
            run_args+=(-e "WAYLAND_DISPLAY=$WAYLAND_DISPLAY"
                       -e "XDG_RUNTIME_DIR=/run/user/$(id -u)"
                       -v "${XDG_RUNTIME_DIR}/${WAYLAND_DISPLAY}:/run/user/$(id -u)/${WAYLAND_DISPLAY}")
        fi

        # Pass through X11 display as fallback
        if [ -n "$DISPLAY" ]; then
            run_args+=(-e "DISPLAY=$DISPLAY")
            [ -e /tmp/.X11-unix ] && run_args+=(-v "/tmp/.X11-unix:/tmp/.X11-unix")
        fi
    fi

    for mount in "${mounts[@]}"; do
        if [[ "$mount" == *:* ]]; then
            run_args+=(-v "$mount")
        else
            run_args+=(-v "$mount:$mount")
        fi
    done

    run_args+=("$image_name" "$shell")
    if [ ${#extra_cmd[@]} -gt 0 ]; then
        run_args+=("${extra_cmd[@]}")
    fi

    echo "Running: $rt ${run_args[*]}"
    "$rt" "${run_args[@]}"
}

cmd_list() {
    local runtime=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --runtime) runtime="$2"; shift 2 ;;
            *) echo "Unknown list option: $1" >&2; exit 1 ;;
        esac
    done

    local rt
    rt=$(detect_runtime "$runtime")

    echo "Dotfiles container images:"
    echo
    "$rt" images --format "table {{.Repository}}\t{{.Tag}}\t{{.Size}}\t{{.CreatedSince}}" | \
        grep -E "(REPOSITORY|${IMAGE_PREFIX})" || echo "  (none found)"
}

cmd_clean() {
    local runtime=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --runtime) runtime="$2"; shift 2 ;;
            *) echo "Unknown clean option: $1" >&2; exit 1 ;;
        esac
    done

    local rt
    rt=$(detect_runtime "$runtime")

    local images
    images=$("$rt" images --format "{{.Repository}}:{{.Tag}}" | grep "^${IMAGE_PREFIX}" || true)

    if [ -z "$images" ]; then
        echo "No dotfiles images found."
        return
    fi

    echo "The following images will be removed:"
    echo "$images" | sed 's/^/  /'
    echo

    read -r -p "Continue? [y/N] " confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        echo "$images" | xargs "$rt" rmi
        echo "Done."
    else
        echo "Cancelled."
    fi
}

usage() {
    cat <<EOF
Usage: $0 <command> [options]

Commands:
  build   Build a container image
  run     Run a container from a built image
  list    List dotfiles container images
  clean   Remove dotfiles container images

Build options:
  --distro <key>           Base distro (default: $DEFAULT_DISTRO)
                           Available: ${!DISTRO_IMAGES[*]}
  --sets <sets>            Comma-separated package sets (default: $ALL_SETS)
  --tag <name>             Image tag (default: derived from distro)
  --runtime <podman|docker> Override runtime detection

Run options:
  --tag <tag>              Image tag to run (default: $DEFAULT_DISTRO)
  --mount <path>           Volume mount (repeatable). host:container or just path
  --network <name>         Container network to join (repeatable). Use a compose
                           network name or 'host' for host networking
  --context <name>         AI config context name (default: default)
  --shell <shell>          Override shell (default: /bin/zsh)
  --gpu                    Enable GPU passthrough (NVIDIA CDI)
  --audit <mode>           strict|soft|off (default: strict, env: DCONT_AUDIT)
  --runtime <podman|docker> Override runtime detection

Run env vars (project pinning, e.g. via .env autoloaded by zsh):
  DCONT_TAG       default --tag
  DCONT_CONTEXT   default --context
  DCONT_SHELL     default --shell
  DCONT_RUNTIME   default --runtime
  DCONT_GPU       enable --gpu when set to 1/true/yes/on
  DCONT_AUDIT     audit mode override (default: strict)
  DCONT_MOUNT     mount(s); single string, or newline-separated for multiple.
                  Additive with --mount on the command line.
  DCONT_NETWORK   network(s); same format/semantics as DCONT_MOUNT.

Examples:
  $0 build
  $0 build --distro tumbleweed --sets cpp-dev,ai-tools
  $0 run --mount /tmp/project
  $0 run --tag tumbleweed --context my-project --mount /home/user/work:/work
  $0 run --network myproject_default --mount /path/to/project
  $0 list
  $0 clean
EOF
}

# --- Main ---

if [ $# -eq 0 ]; then
    usage
    exit 1
fi

command="$1"
shift

case "$command" in
    build) cmd_build "$@" ;;
    run)   cmd_run "$@" ;;
    list)  cmd_list "$@" ;;
    clean) cmd_clean "$@" ;;
    -h|--help|help) usage ;;
    *) echo "Unknown command: $command" >&2; usage; exit 1 ;;
esac
